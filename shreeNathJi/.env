# Application Configuration
# LOG_VERBOSE options:
# - "debug" or "console" or "1" = Console debug logs only
# - "file" or "2" = Write logs to file only
# - "both" or "all" or "3" = Both console and file logs
# - "false" or "0" = No logging
LOG_VERBOSE=file

# Server Configuration  
PORT=8081

# Database Configuration
# MONGO_URI=mongodb://localhost:27017
